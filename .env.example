# Comma-separated list of HTTP upstream base URLs
UPSTREAMS=http://localhost:9000,http://localhost:9001
# Optional WS upstreams (if omitted, HTTP upstreams are used)
WS_UPSTREAMS=
# Enabled protocols: http,ws (comma-separated)
PROTOCOLS=http,ws
# random | round_robin
UPSTREAM_STRATEGY=random
CONNECT_TIMEOUT=5
READ_TIMEOUT=30
MAX_BODY_BYTES=5242880
HEALTH_WINDOW_SECONDS=60
